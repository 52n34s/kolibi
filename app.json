{
  "expo": {
    "name": "Kolibi",
    "slug": "kolibi",
    "version": "1.0.0",
    "orientation": "portrait",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6a372771-7ca2-4394-aba0-18b08be64383"
    },
    "icon": "./assets/images/kolibi-app-icon.png",
    "scheme": "kolibitemp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.steffen.kolibi",
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSHealthShareUsageDescription": "Kolibi liest deine verbrannten Kalorien aus Apple Health, damit dein Tagesziel deine Aktivität berücksichtigt.",
        "NSHealthUpdateUsageDescription": "Kolibi schreibt deine erfassten Kalorien nach Apple Health, damit sie dort zusammen mit deinen anderen Gesundheitsdaten sichtbar sind."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.steffen.kolibi"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/koli-happy.png",
          "color": "#4F46E5"
        }
      ],
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.543613260072-7g56l864f40jo3hp420gafahqsp5qgaq"
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker",
      "@kingstinct/react-native-healthkit",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Kolibi to access your photos to set a profile picture.",
          "cameraPermission": "Allow Kolibi to access your camera to take a profile picture and scan meals."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Kolibi to access your camera to scan meals and barcodes.",
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      "./plugins/with-ios-modular-headers.js",
      "expo-asset",
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "kolibi",
          "organization": "52n34s-group"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6a372771-7ca2-4394-aba0-18b08be64383"
      }
    }
  }
}
